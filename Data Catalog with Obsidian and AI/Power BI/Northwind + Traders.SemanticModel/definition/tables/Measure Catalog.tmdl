	partition 'Measure Catalog' = calculated
		mode: import
		source =
				DATATABLE(
				    "Measure Name", STRING,
				    "DAX Expression", STRING,
				    "Format String", STRING,
				    "Description", STRING,
				    {
				        {"Total Sales", "SUMX(Fact_OrderDetail, Fact_OrderDetail[Unit Price] * Fact_OrderDetail[Quantity Ordered] * (1 - Fact_OrderDetail[Discount Rate]))", "$#,0.00", "Total net sales for all order lines, calculated as Unit Price x Quantity Ordered x (1 - Discount Rate). Uses line item detail and reflects current filter context."},
				        {"Total Quantity", "SUM(Fact_OrderDetail[Quantity Ordered])", "0", "Total units sold, calculated as the sum of Quantity Ordered from all order lines in the current filter context."},
				        {"Order Count", "DISTINCTCOUNT(Fact_Order[Order ID])", "0", "Number of distinct orders based on Order ID in the current filter context."},
				        {"Average Order Value", "DIVIDE([Total Sales], [Order Count])", "$#,0.00", "Average sales per order, calculated as Total Sales divided by Order Count for the current filter context."},
				        {"Total Discount Amount", "SUMX(Fact_OrderDetail, Fact_OrderDetail[Unit Price] * Fact_OrderDetail[Quantity Ordered] * Fact_OrderDetail[Discount Rate])", "$#,0.00", "Total discount value given, calculated as Unit Price x Quantity Ordered x Discount Rate across all order lines."},
				        {"Average Discount Rate", "AVERAGE(Fact_OrderDetail[Discount Rate])", "0.00%", "Average line-item discount rate (0-1 scale) across the current filter context."},
				        {"Late Orders Count", "COUNTROWS(FILTER(Fact_Order, Fact_Order[Days Late] > 0))", "0", "Count of orders with Days Late > 0 in the current filter context."},
				        {"Late Orders %", "DIVIDE([Late Orders Count], [Order Count])", "0.00%", "Percent of orders that were late, calculated as Late Orders Count divided by Order Count."},
				        {"Average Days to Ship", "AVERAGE(Fact_Order[Days to Ship])", "0", "Average number of days from order date to shipped date, using Days to Ship in the current filter context."},
				
				        {"Total Sales - Current", "CALCULATE([Total Sales], 'Time Intelligence'[Time Intelligence] = ""Current"")", "$#,0.00", "Total Sales for the current period. Applies Time Intelligence calculation item 'Current'."},
				        {"Total Sales - Prior Year", "CALCULATE([Total Sales], 'Time Intelligence'[Time Intelligence] = ""Prior Year"")", "$#,0.00", "Total Sales for the same period in the prior year. Applies Time Intelligence calculation item 'Prior Year'."},
				        {"Total Sales - YoY", "CALCULATE([Total Sales], 'Time Intelligence'[Time Intelligence] = ""YoY"")", "$#,0.00", "Year-over-year change in Total Sales (current period minus prior year). Applies Time Intelligence calculation item 'YoY'."},
				        {"Total Sales - YoY %", "CALCULATE([Total Sales], 'Time Intelligence'[Time Intelligence] = ""YoY %"")", "0.00%", "Year-over-year percent change in Total Sales. Applies Time Intelligence calculation item 'YoY %'."},
				        {"Total Sales - YTD", "CALCULATE([Total Sales], 'Time Intelligence'[Time Intelligence] = ""YTD"")", "$#,0.00", "Total Sales year-to-date based on Dim_Calendar[Date]. Applies Time Intelligence calculation item 'YTD'."},
				        {"Total Sales - QTD", "CALCULATE([Total Sales], 'Time Intelligence'[Time Intelligence] = ""QTD"")", "$#,0.00", "Total Sales quarter-to-date based on Dim_Calendar[Date]. Applies Time Intelligence calculation item 'QTD'."},
				        {"Total Sales - MTD", "CALCULATE([Total Sales], 'Time Intelligence'[Time Intelligence] = ""MTD"")", "$#,0.00", "Total Sales month-to-date based on Dim_Calendar[Date]. Applies Time Intelligence calculation item 'MTD'."},
				
				        {"Total Quantity - Current", "CALCULATE([Total Quantity], 'Time Intelligence'[Time Intelligence] = ""Current"")", "0", "Total Quantity for the current period. Applies Time Intelligence calculation item 'Current'."},
				        {"Total Quantity - Prior Year", "CALCULATE([Total Quantity], 'Time Intelligence'[Time Intelligence] = ""Prior Year"")", "0", "Total Quantity for the same period in the prior year. Applies Time Intelligence calculation item 'Prior Year'."},
				        {"Total Quantity - YoY", "CALCULATE([Total Quantity], 'Time Intelligence'[Time Intelligence] = ""YoY"")", "0", "Year-over-year change in Total Quantity. Applies Time Intelligence calculation item 'YoY'."},
				        {"Total Quantity - YoY %", "CALCULATE([Total Quantity], 'Time Intelligence'[Time Intelligence] = ""YoY %"")", "0.00%", "Year-over-year percent change in Total Quantity. Applies Time Intelligence calculation item 'YoY %'."},
				        {"Total Quantity - YTD", "CALCULATE([Total Quantity], 'Time Intelligence'[Time Intelligence] = ""YTD"")", "0", "Total Quantity year-to-date based on Dim_Calendar[Date]. Applies Time Intelligence calculation item 'YTD'."},
				        {"Total Quantity - QTD", "CALCULATE([Total Quantity], 'Time Intelligence'[Time Intelligence] = ""QTD"")", "0", "Total Quantity quarter-to-date based on Dim_Calendar[Date]. Applies Time Intelligence calculation item 'QTD'."},
				        {"Total Quantity - MTD", "CALCULATE([Total Quantity], 'Time Intelligence'[Time Intelligence] = ""MTD"")", "0", "Total Quantity month-to-date based on Dim_Calendar[Date]. Applies Time Intelligence calculation item 'MTD'."},
				
